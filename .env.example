# Copy this file to .env and fill in your values.
# The .env file is gitignored and should NEVER be committed.

# ── Provider ────────────────────────────────────────────────────────────────
# Options: ollama | openai | openrouter
RAG_LLM_PROVIDER=openrouter

# ── OpenRouter (free tier – no credit card required) ────────────────────────
# Get your free key at: https://openrouter.ai/keys
RAG_OPENROUTER_API_KEY=sk-or-v1-...

# Free models (append :free to the model name):
#   meta-llama/llama-3.2-3b-instruct:free
#   google/gemma-3-4b-it:free
#   mistralai/mistral-7b-instruct:free
#   deepseek/deepseek-r1:free
# See all free models: https://openrouter.ai/models?q=:free
RAG_OPENROUTER_LANGUAGE_MODEL=meta-llama/llama-3.2-3b-instruct:free

# Sentence-transformers model for local embeddings (used with openrouter)
RAG_HUGGINGFACE_EMBEDDING_MODEL=all-MiniLM-L6-v2

# ── OpenAI (optional) ───────────────────────────────────────────────────────
# RAG_OPENAI_API_KEY=sk-...
# RAG_OPENAI_LANGUAGE_MODEL=gpt-4o-mini
# RAG_OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ── Ollama (local, default) ──────────────────────────────────────────────────
# RAG_OLLAMA_BASE_URL=http://localhost:11434
# RAG_OLLAMA_LANGUAGE_MODEL=hf.co/bartowski/Llama-3.2-1B-Instruct-GGUF
# RAG_OLLAMA_EMBEDDING_MODEL=hf.co/CompendiumLabs/bge-base-en-v1.5-gguf

# ── Data & Storage ───────────────────────────────────────────────────────────
# RAG_FEEDBACK_DATA_PATH=./feedback_data.json
# RAG_CHROMA_PERSIST_DIR=./chroma_db

# ── Retrieval ────────────────────────────────────────────────────────────────
# RAG_RETRIEVAL_TOP_K=5
# RAG_RETRIEVAL_BM25_WEIGHT=0.4
# RAG_RETRIEVAL_SEMANTIC_WEIGHT=0.6

# ── Agent ────────────────────────────────────────────────────────────────────
# RAG_TEMPERATURE=0.1
